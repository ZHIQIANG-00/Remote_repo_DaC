<decoder name="nozomi_n2os">
  <type>syslog</type>
  <prematch>CEF:0\|Nozomi Networks\|N2OS\|</prematch>
</decoder>

<decoder name="nozomi_n2os_fields"> 
  <parent>nozomi_n2os</parent> 
  <regex type="pcre2">CEF:([0-9]+)\|Nozomi Networks\|N2OS\|([^|]+)\|([^|]+)\|([^|]+)\|([0-9]+)\|</regex> 
  <order>cef_version, product_version, signature, event_name, severity</order> 
</decoder>

<decoder name="nozomi_n2os_fields">
    <parent>nozomi_n2os</parent>
    <regex type="pcre2">app=([^\s]+)\s+dvc=([0-9.]+)\s+dvchost=([^\s]+)</regex>
    <order>app,device_ip,device_hostname</order>
</decoder>

<decoder name="nozomi_n2os_fields">
    <parent>nozomi_n2os</parent>
    <regex type="pcre2">cs1=([^\s]+)\s+cs2=([^\s]+)\s+cs3=([^\s]+)</regex>
    <order>risk, is_security, event_id</order>
</decoder>

<decoder name="nozomi_n2os_fields">
    <parent>nozomi_n2os</parent>
    <regex type="pcre2">cs5=\["([^"]+)"</regex>
    <order>parent_id</order>
</decoder>

<decoder name="nozomi_n2os_fields">
    <parent>nozomi_n2os</parent>
    <regex type="pcre2">dst=([0-9.]+).*dpt=([0-9]+).*src=([0-9.]+).*spt=([0-9]+).*proto=([A-Za-z]+)</regex>
    <order>dstip,dstport,srcip,srcport,protocol</order>
</decoder>

<decoder name="nozomi_n2os_fields">
    <parent>nozomi_n2os</parent>
    <regex type="pcre2">dhost=([^\s]+).*dmac=([0-9A-Fa-f:]+).*smac=([0-9A-Fa-f:]+)</regex>
    <order>dsthost,dstmac,srcmac</order>
</decoder>

<decoder name="nozomi_n2os_fields">
    <parent>nozomi_n2os</parent>
    <regex type="pcre2">msg=(.*?)\s+src</regex>
    <order>message</order>
</decoder>