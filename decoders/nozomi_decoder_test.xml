<decoder_list>

  <decoder name="nozomi-cef">
    <prematch>CEF:0|Nozomi Networks|N2OS|</prematch>
  </decoder>

  <!-- ============================================================
       CEF HEADER
       Extracts the 7 standard fields from the CEF header pipe format:
       CEF:Version|Vendor|Product|DevVersion|SignatureID|Name|Severity|
       ============================================================ -->
  <decoder name="nozomi-cef-header">
    <parent>nozomi-cef</parent>
    <regex>CEF:(\d+)\|([^|]+)\|([^|]+)\|([^|]+)\|([^|]+)\|([^|]+)\|(\d+)\|</regex>
    <order>cef.version,cef.device_vendor,cef.device_product,cef.device_version,cef.signature_id,cef.name,cef.severity</order>
  </decoder>


  <!-- Source IP address (attacker/origin) -->
  <decoder name="nozomi-cef-src">
    <parent>nozomi-cef</parent>
    <regex>src=(\d+\.\d+\.\d+\.\d+)</regex>
    <order>srcip</order>
  </decoder>

  <!-- Destination IP address (target) -->
  <decoder name="nozomi-cef-dst">
    <parent>nozomi-cef</parent>
    <regex>dst=(\d+\.\d+\.\d+\.\d+)</regex>
    <order>dstip</order>
  </decoder>

  <!-- Source port -->
  <decoder name="nozomi-cef-spt">
    <parent>nozomi-cef</parent>
    <regex>spt=(\d+)</regex>
    <order>srcport</order>
  </decoder>

  <!-- Destination port -->
  <decoder name="nozomi-cef-dpt">
    <parent>nozomi-cef</parent>
    <regex>dpt=(\d+)</regex>
    <order>dstport</order>
  </decoder>

  <!-- Network protocol (e.g. TCP, UDP) -->
  <decoder name="nozomi-cef-proto">
    <parent>nozomi-cef</parent>
    <regex>proto=(\w+)</regex>
    <order>protocol</order>
  </decoder>

  <!-- msg = human readable alert description -->
  <decoder name="nozomi-cef-msg">
    <parent>nozomi-cef</parent>
    <regex>msg=(.+?)(?=\s+\w+=|$)</regex>
    <order>nozomi.message</order>
  </decoder>

  <!-- start = event timestamp (epoch milliseconds) -->
  <decoder name="nozomi-cef-start">
    <parent>nozomi-cef</parent>
    <regex>start=(\d+)</regex>
    <order>nozomi.event_start</order>
  </decoder>

</decoder_list>
